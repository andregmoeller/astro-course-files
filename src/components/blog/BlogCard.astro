---
import type { CollectionEntry } from "astro:content";

import { getEntry } from "astro:content";
import Heading from "@/ui/Heading.astro";
import FormattedDate from "@/ui/FormattedDate.astro";
import Link from "@/ui/Link.astro";

type Props = {
  post: CollectionEntry<"blogPosts">;
  tagName: "h2" | "h3";
};

const { post, tagName } = Astro.props;
const { title, image, slug, description, pubDate } = post.data;
const author = await getEntry(post.data.author.collection, post.data.author.id);
---

<article aria-label={title} class="blog-card">
  <img src={image.src} width={400} height={225} alt="" transition:name={`${slug}-image`} />
  <div class="rows">
    <Heading tagName={tagName} tagSize="h3" transition:name={`${slug}-title`}>
      {title}
    </Heading>
    <div class="columns">
      <FormattedDate pubDate={pubDate} transition:name={`${slug}-date`} />
      {author && <small>by {author.data.name}</small>}
    </div>
    <p transition:name={`${slug}-description`}>{description}</p>
    <Link href={`/blog/${slug}`}>Read Post</Link>
  </div>
</article>
