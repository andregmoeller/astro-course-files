---
import ProjectWrapper from "@/components/project/Projects.astro";
import Heading from "@/components/ui/Heading.astro";
import Layout from "@/layouts/Layout.astro";
---

<Layout title="My Recent Projects">
  <video controls autoplay muted playsinline transition:persist="video">
    <source
      src="https://ia804502.us.archive.org/33/items/GoldenGa1939_3/GoldenGa1939_3_512kb.mp4"
      type="video/mp4"
    />
  </video>
  <div class="container rows">
    <Heading tagName="h1" tagSize="h1">Latest Projects</Heading>
    <ProjectWrapper tagName="h2" />
  </div>
</Layout>
